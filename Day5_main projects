# cache
def make_cache():
	cache = {}
	
	def calc(n):
		if n in cache:
			print("from cache")
			return cache
			
		print("calculating")
		result = n * n
		cache[n] = result
		return result
		
	return calc

square = (make_cache())

print(square(4))
print(square(4))

# here comes greatest one
def stats(marks):
    
    # Mean
    mean = sum(marks) / len(marks)

    # Median
    sorted_marks = sorted(marks)
    n = len(sorted_marks)

    if n % 2 == 1:
        median = sorted_marks[n // 2]
    else:
        median = (sorted_marks[n // 2 - 1] + sorted_marks[n // 2]) / 2

    # Max & Min
    maximum = max(marks)
    minimum = min(marks)

    return mean, median, maximum, minimum


marks = [45, 67, 89, 56, 78]

result = stats(marks)

print("Mean, Median, Max, Min:")
print(result)
