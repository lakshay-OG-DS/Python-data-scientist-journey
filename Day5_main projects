def bmi(height,weight):
	value = weight/(height)**2
	
	if value < 18.5:
		print("under weight")
	elif value < 20:
		print("normal")
	elif value < 40:
		print("over weight")
	else:
		print("obese")
	return value
print(bmi(1.73,45))

def nums(*args):
	result = [ ]
	for n in args:
			if n % 2 == 0:
				result.append(n)
	return result
print(nums(17,8,86,62,2,3,4,5,6,7,8,9,68))
		
