class BankSystem:
	def __init__(self):
		self.account = []
	
	def add_account(self, name, balance):
		name = name.lower().strip()
		self.account.append({
			"name": name,
			"balance": balance
		})
	
	def filter_account(self, amount):
		result = []
		for acc in self.account:
			if acc["balance"] > amount:
				result.append(acc)
		return result
	
	def info(self):
		for acc in self.account:
			print("name:", acc["name"], "balance:", acc["balance"])


