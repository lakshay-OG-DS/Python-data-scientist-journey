class grades:
	
	def __init__(self,name,marks):
		self.name = name
		self.marks = marks
		
	def classify(self):
		if self.marks < 0 or self.marks > 100:
			print(self.name,"grade :invalid")
		elif self.marks >= 90:
			print(self.name,"grade :excellent")
		elif self.marks >= 70:
			print(self.name,"grade :great")
		elif self.marks >= 40:
			print(self.name,"grade :average")
		else:
			print(self.name,"grade : bad")
			
