class BankAccount:
	
	def __init__(self, balance,intrest_rate):
		self.balance = balance
		self.intrest_rate = intrest_rate
	
	def deposit(self, amount):
		self.balance += amount
		print("money deposited: ",amount)
		print("money deposited total currency", self.balance)
	
	def withdraw(self, amount):
		if amount > self.balance:
			print("cannot withdraw this amount: ",amount)
			print("not enough money")
		else:
			self.balance -= amount
			print("money withdrawed: ",amount)
			print("money withdrawed money left:", self.balance)
		
	def get_balance(self,balance):
		print("your current balance is : ",self.balance)
		
	def apply_intrest(self):
		intrest = self.balance * self.intrest_rate/ 100
		self.balance += intrest
		print("money in intrest: ",intrest)
		print("money after intrest",self.balance)
	
