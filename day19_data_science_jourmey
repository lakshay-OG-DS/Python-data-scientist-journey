# Palindrome: string that reads same forwards and backwards
# Use case: interview question to test string manipulation

def is_palindrome(s):
    # Convert to lowercase and remove spaces
    s = s.lower().replace("", "")
    # Compare with reverse using slicing
    return s == s[::-1]

# Test
print(is_palindrome("eye"))  # True

